  m_Name: 
  m_EditorClassIdentifier: 
  messageOutput: {fileID: 353088441}
  OnComplete:
    m_PersistentCalls:
      m_Calls: []
  messages:
  - Press the button on the table to generate a 5kg block
  - Put a block on each side to balance the lever
  - Move one of the blocks closer to the center and see what happens
  - Put a lighter block on the end to balance the 1kg block near the center
  - Try moving the pivot point to one side, then try to balance the lever
